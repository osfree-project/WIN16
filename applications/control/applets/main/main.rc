/* ----- Date/Time ----- */
DLG_DATETIME DIALOG FIXED IMPURE 6, 0, 200, 162
STYLE DS_MODALFRAME | WS_POPUPWINDOW | WS_DLGFRAME
CAPTION "Date & Time"
FONT 8, "Helv"
BEGIN
    CONTROL "",       IDC_CALENDAR, "STATIC", SS_BLACKFRAME | WS_CHILD | WS_VISIBLE, 4, 4, 82, 82
    CONTROL "&Date",  IDC_DT_DATE_GROUP, "BUTTON", BS_GROUPBOX | WS_CHILD | WS_VISIBLE, 4, 88, 80, 26
    CONTROL "",       IDC_DT_MONTH, "EDIT", ES_CENTER | ES_MULTILINE | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 8, 102, 8, 9
    CONTROL "/",      IDC_DT_SEP_DATE1, "STATIC", SS_CENTER | SS_NOPREFIX | WS_CHILD | WS_VISIBLE | WS_GROUP, 16, 102, 8, 9
