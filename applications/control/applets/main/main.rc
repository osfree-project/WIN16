#include <windows.h>
#include "main.h"

IDI_MOUSE ICON "mouse.ico"
IDI_KEYBOARD ICON "keyboard.ico"
IDI_TIME ICON "time.ico"
IDI_FONTS ICON "fonts.ico"
IDI_COLORS ICON "colors.ico"
IDI_PRINTERS ICON "printers.ico"
IDI_DESKTOP ICON "desktop.ico"
IDI_INTL ICON "inter.ico"
IDI_NETWORK ICON "network.ico"

STRINGTABLE BEGIN
    IDS_COLOR_NAME,  "Color"
    IDS_COLOR_INFO,  "Change the color scheme"
    IDS_FONTS_NAME,  "Fonts"
    IDS_FONTS_INFO,  "Add or remove fonts"
    IDS_PORTS_NAME,  "Ports"
    IDS_PORTS_INFO,  "Configure serial and parallel ports"
    IDS_MOUSE_NAME,  "Mouse"
    IDS_MOUSE_INFO,  "Change mouse settings"
    IDS_DESKTOP_NAME, "Desktop"
    IDS_DESKTOP_INFO, "Change desktop appearance"
    IDS_KEYBOARD_NAME, "Keyboard"
    IDS_KEYBOARD_INFO, "Change keyboard repeat rate and delay"
    IDS_PRINTERS_NAME, "Printers"
    IDS_PRINTERS_INFO, "Add, remove, and configure printers"
    IDS_INTERNATIONAL_NAME, "International"
    IDS_INTERNATIONAL_INFO, "Change country, language, and number formats"
    IDS_DATETIME_NAME, "Date/Time"
    IDS_DATETIME_INFO, "Change system date and time"
    IDS_NETWORK_NAME, "Network"
    IDS_NETWORK_INFO, "Configure network settings"
END

/* ----- Color ----- */
DLG_COLOR DIALOG 10, 10, 220, 200
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Color"
BEGIN
    LTEXT           "Color Schemes", -1, 10, 10, 200, 12
    COMBOBOX        IDC_COL_SCHEMES, 10, 25, 200, 80, CBS_DROPDOWNLIST | WS_VSCROLL
    GROUPBOX        "Screen Element", -1, 10, 50, 200, 70
    LISTBOX         IDC_COL_ELEMENTS, 15, 65, 100, 50, LBS_STANDARD | WS_VSCROLL
    CONTROL         "", IDC_COL_SAMPLE, "static", SS_BLACKFRAME, 125, 65, 80, 50
    PUSHBUTTON      "Color Palette...", IDC_COL_CHANGE, 10, 130, 100, 14
    PUSHBUTTON      "Default Colors", IDC_COL_DEFCOLORS, 120, 130, 90, 14
    DEFPUSHBUTTON   "OK", IDOK, 50, 160, 50, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 120, 160, 50, 14
END

/* ----- Fonts ----- */
DLG_FONTS DIALOG 10, 10, 230, 200
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Fonts"
BEGIN
    LISTBOX         IDC_FNT_LIST, 10, 10, 120, 100, LBS_STANDARD | WS_VSCROLL
    LTEXT           "Sample", -1, 140, 10, 80, 12
    CONTROL         "", IDC_FNT_SAMPLE, "static", SS_BLACKFRAME, 140, 25, 80, 40
    PUSHBUTTON      "Add...", IDC_FNT_ADD, 20, 120, 50, 14
    PUSHBUTTON      "Remove", IDC_FNT_REMOVE, 90, 120, 50, 14
    DEFPUSHBUTTON   "OK", IDOK, 50, 150, 50, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 120, 150, 50, 14
END

/* ----- Ports ----- */
DLG_PORTS DIALOG 10, 10, 150, 150
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Ports"
BEGIN
    LISTBOX         IDC_PRT_LIST, 10, 10, 130, 60, LBS_STANDARD | WS_VSCROLL
    PUSHBUTTON      "Settings...", IDC_PRT_SETTINGS, 35, 80, 80, 14
    DEFPUSHBUTTON   "OK", IDOK, 20, 110, 50, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 80, 110, 50, 14
END

/* ----- Mouse (âîńďđîčçâĺäĺíčĺ äčŕëîăŕ Windows 3.0) ----- */
DLG_MOUSE DIALOG FIXED IMPURE 10, 10, 200, 104
STYLE DS_MODALFRAME | WS_POPUPWINDOW | WS_DLGFRAME
CAPTION "Mouse"
FONT 8, "Helv"
BEGIN
    CONTROL "&Mouse Tracking Speed",    -1, "BUTTON", BS_GROUPBOX | WS_CHILD | WS_VISIBLE, 4, 4, 96, 36
    CONTROL "Slow",                     -1, "STATIC", SS_LEFT | WS_CHILD | WS_VISIBLE | WS_GROUP, 6, 16, 44, 9
    CONTROL "Fast",                     -1, "STATIC", SS_RIGHT | WS_CHILD | WS_VISIBLE | WS_GROUP, 54, 16, 44, 9
    CONTROL "",                         IDC_MS_SPEED, "SCROLLBAR", SBS_HORZ | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 6, 26, 92, 12
    CONTROL "&Double Click Speed",      -1, "BUTTON", BS_GROUPBOX | WS_CHILD | WS_VISIBLE, 4, 44, 96, 56
    CONTROL "Slow",                     -1, "STATIC", SS_LEFT | WS_CHILD | WS_VISIBLE | WS_GROUP, 6, 56, 44, 9
    CONTROL "Fast",                     -1, "STATIC", SS_RIGHT | WS_CHILD | WS_VISIBLE | WS_GROUP, 54, 56, 44, 9
    CONTROL "",                         IDC_MS_DOUBLECLICK, "SCROLLBAR", SBS_HORZ | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 6, 66, 92, 12
    CONTROL "",                         IDC_MS_TEST, "STATIC", SS_BLACKFRAME | WS_CHILD | WS_VISIBLE, 31, 80, 36, 16
    CONTROL "TEST",                     -1, "STATIC", SS_CENTER | SS_NOPREFIX | WS_CHILD | WS_VISIBLE | WS_GROUP, 33, 84, 32, 9
    CONTROL "&Swap Left/Right Buttons", IDC_MS_SWAP, "BUTTON", BS_AUTOCHECKBOX | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 104, 78, 158, 12
    CONTROL "",                         IDC_MS_BUTTON_FRAME, "STATIC", SS_BLACKFRAME | WS_CHILD | WS_VISIBLE, 108, 21, 42, 50
    CONTROL "",                         IDC_MS_L_FRAME, "STATIC", SS_BLACKFRAME | WS_CHILD | WS_VISIBLE, 108, 21, 21, 14
    CONTROL "",                         IDC_MS_R_FRAME, "STATIC", SS_BLACKFRAME | WS_CHILD | WS_VISIBLE, 129, 21, 21, 14
    CONTROL "L",                        IDC_MS_L, "STATIC", SS_CENTER | SS_NOPREFIX | WS_CHILD | WS_VISIBLE | WS_GROUP, 109, 24, 19, 8
    CONTROL "R",                        IDC_MS_R, "STATIC", SS_CENTER | SS_NOPREFIX | WS_CHILD | WS_VISIBLE | WS_GROUP, 130, 24, 19, 8
    CONTROL "OK",                       IDOK, "BUTTON", BS_DEFPUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 160, 4, 36, 14
    CONTROL "Cancel",                   IDCANCEL, "BUTTON", BS_PUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 160, 20, 36, 14
END

/* ----- Desktop ----- */
DLG_DESKTOP DIALOG FIXED IMPURE 8, 2, 200, 158
STYLE DS_MODALFRAME | WS_POPUPWINDOW | WS_DLGFRAME
CAPTION "Desktop"
FONT 8, "Helv"
BEGIN
    CONTROL "Pattern",            99, "BUTTON", BS_GROUPBOX | WS_CHILD | WS_VISIBLE, 4, 2, 130, 40
    CONTROL "&Name:",             99, "STATIC", SS_LEFT | WS_CHILD | WS_VISIBLE | WS_GROUP, 10, 14, 20, 10
    CONTROL "",                   IDC_DT_PATTERN_COMBO, "COMBOBOX", CBS_DROPDOWNLIST | CBS_SORT | WS_CHILD | WS_VISIBLE | WS_VSCROLL | WS_TABSTOP, 32, 12, 90, 55
    CONTROL "Edit &Pattern...",   IDC_DT_EDIT_PATTERN, "BUTTON", BS_PUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_TABSTOP, 44, 26, 60, 14
    CONTROL "Wallpaper",          99, "BUTTON", BS_GROUPBOX | WS_CHILD | WS_VISIBLE, 4, 46, 94, 58
    CONTROL "&File:",             99, "STATIC", SS_LEFT | WS_CHILD | WS_VISIBLE | WS_GROUP, 10, 58, 20, 10
    CONTROL "",                   IDC_DT_WALLPAPER_COMBO, "COMBOBOX", CBS_DROPDOWN | CBS_AUTOHSCROLL | CBS_SORT | WS_CHILD | WS_VISIBLE | WS_VSCROLL | WS_TABSTOP, 32, 58, 62, 55
    CONTROL "&Center",            IDC_DT_CENTER, "BUTTON", BS_RADIOBUTTON | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 44, 74, 39, 12
    CONTROL "&Tile",              IDC_DT_TILE, "BUTTON", BS_RADIOBUTTON | WS_CHILD | WS_VISIBLE, 44, 88, 32, 12
    CONTROL "Icons",              99, "BUTTON", BS_GROUPBOX | WS_CHILD | WS_VISIBLE, 102, 78, 94, 26
    CONTROL "&Icon Spacing:",     99, "STATIC", SS_LEFT | WS_CHILD | WS_VISIBLE | WS_GROUP, 106, 90, 54, 9
    CONTROL "",                   IDC_DT_ICON_SPACING, "EDIT", ES_LEFT | WS_CHILD | WS_VISIBLE | WS_BORDER | WS_GROUP | WS_TABSTOP, 164, 88, 18, 12
    CONTROL "Cursor Blink &Rate", -1, "BUTTON", BS_GROUPBOX | WS_CHILD | WS_VISIBLE | WS_GROUP, 4, 108, 94, 48
    CONTROL "Slow",               -1, "STATIC", SS_LEFT | WS_CHILD | WS_VISIBLE | WS_GROUP, 6, 120, 40, 9
    CONTROL "Fast",               -1, "STATIC", SS_RIGHT | WS_CHILD | WS_VISIBLE | WS_GROUP, 56, 120, 40, 9
    CONTROL "",                   IDC_DT_CURSOR_SPEED, "SCROLLBAR", SBS_HORZ | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 6, 132, 90, 10
    CONTROL "",                   IDC_DT_CARET, "STATIC", SS_LEFT | WS_CHILD | WS_VISIBLE, 48, 146, 1, 8
    CONTROL "Sizing Grid",        99, "BUTTON", BS_GROUPBOX | WS_CHILD | WS_VISIBLE, 102, 108, 94, 48
    CONTROL "&Granularity:",      99, "STATIC", SS_LEFT | WS_CHILD | WS_VISIBLE | WS_GROUP, 106, 124, 54, 9
    CONTROL "",                   IDC_DT_GRANULARITY, "EDIT", ES_LEFT | WS_CHILD | WS_VISIBLE | WS_BORDER | WS_GROUP | WS_TABSTOP, 164, 122, 18, 12
    CONTROL "&Border Width:",     -1, "STATIC", SS_LEFT | WS_CHILD | WS_VISIBLE | WS_GROUP, 106, 138, 54, 9
    CONTROL "",                   IDC_DT_BORDER_WIDTH, "EDIT", ES_LEFT | WS_CHILD | WS_VISIBLE | WS_BORDER | WS_GROUP | WS_TABSTOP, 164, 136, 18, 12
    CONTROL "OK",                 IDOK, "BUTTON", BS_DEFPUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 146, 12, 44, 14
    CONTROL "Cancel",             IDCANCEL, "BUTTON", BS_PUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 146, 28, 44, 14
END

/* ----- Keyboard ----- */
DLG_KEYBOARD DIALOG FIXED IMPURE 6, 0, 170, 68
STYLE DS_MODALFRAME | WS_POPUPWINDOW | WS_DLGFRAME
CAPTION "Keyboard"
FONT 8, "Helv"
BEGIN
    CONTROL "Key &Repeat Rate", -1, "BUTTON", BS_GROUPBOX | WS_CHILD | WS_VISIBLE, 6, 6, 120, 60
    CONTROL "Slow",             -1, "STATIC", SS_LEFT | WS_CHILD | WS_VISIBLE | WS_GROUP, 10, 16, 50, 9
    CONTROL "Fast",             -1, "STATIC", SS_RIGHT | WS_CHILD | WS_VISIBLE | WS_GROUP, 72, 16, 50, 9
    CONTROL "",                 IDC_KB_SPEED, "SCROLLBAR", SBS_HORZ | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 10, 26, 112, 12
    CONTROL "&Test Typematic:", -1, "STATIC", SS_LEFT | WS_CHILD | WS_VISIBLE | WS_GROUP, 10, 40, 112, 9
    CONTROL "",                 IDC_KB_TEST, "EDIT", ES_LEFT | WS_CHILD | WS_VISIBLE | WS_BORDER | WS_GROUP | WS_TABSTOP, 10, 50, 112, 12
    CONTROL "OK",               IDOK, "BUTTON", BS_DEFPUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 130, 10, 36, 14
    CONTROL "Cancel",           IDCANCEL, "BUTTON", BS_PUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 130, 28, 36, 14
END

/* ----- Printers ----- */
DLG_PRINTERS DIALOG 10, 10, 230, 160
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Printers"
BEGIN
    LISTBOX         IDC_PRN_LIST, 10, 10, 210, 60, LBS_STANDARD | WS_VSCROLL
    PUSHBUTTON      "Connect...", IDC_PRN_CONNECT, 10, 80, 60, 14
    PUSHBUTTON      "Setup...", IDC_PRN_SETUP, 80, 80, 60, 14
    PUSHBUTTON      "Remove", IDC_PRN_REMOVE, 150, 80, 60, 14
    DEFPUSHBUTTON   "OK", IDOK, 50, 110, 50, 14
    PUSHBUTTON      "Cancel", IDCANCEL, 130, 110, 50, 14
END

DLG_DATEFMT DIALOG FIXED IMPURE  0, 0, 210, 168
STYLE DS_MODALFRAME | WS_POPUPWINDOW | WS_VISIBLE | WS_DLGFRAME
CAPTION "International - Date Format"
FONT 8, "Helv"
BEGIN
    CONTROL "Short Date Format",              -1, "BUTTON", BS_GROUPBOX | WS_CHILD | WS_VISIBLE, 6, 4, 150, 88
    CONTROL "&Order:",                        -1, "STATIC", SS_LEFT | WS_CHILD | WS_VISIBLE | WS_GROUP, 10, 18, 40, 9
    CONTROL "MDY",                            IDC_DATEFMT_S_MDY, "BUTTON", BS_AUTORADIOBUTTON | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 54, 16, 30, 12
    CONTROL "DMY",                            IDC_DATEFMT_S_DMY, "BUTTON", BS_AUTORADIOBUTTON | WS_CHILD | WS_VISIBLE, 86, 16, 30, 12
    CONTROL "YMD",                            IDC_DATEFMT_S_YMD, "BUTTON", BS_AUTORADIOBUTTON | WS_CHILD | WS_VISIBLE, 118, 16, 30, 12
    CONTROL "&Separator:",                    -1, "STATIC", SS_LEFT | WS_CHILD | WS_VISIBLE | WS_GROUP, 10, 34, 40, 9
    CONTROL "",                               IDC_DATEFMT_SEPARATOR, "EDIT", ES_CENTER | ES_OEMCONVERT | WS_CHILD | WS_VISIBLE | WS_BORDER | WS_GROUP | WS_TABSTOP, 54, 32, 12, 12
    CONTROL "&Day Leading Zero (07 vs. 7)",   IDC_DATEFMT_S_DAYLZ, "BUTTON", BS_CHECKBOX | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 10, 50, 142, 12
    CONTROL "&Month Leading Zero (02 vs. 2)", IDC_DATEFMT_S_MONTHLZ, "BUTTON", BS_CHECKBOX | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 10, 64, 142, 12
    CONTROL "&Century (1990 vs. 90)",         IDC_DATEFMT_S_CENTURY, "BUTTON", BS_CHECKBOX | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 10, 78, 142, 12
    CONTROL "Long Date Format",               -1, "BUTTON", BS_GROUPBOX | WS_CHILD | WS_VISIBLE, 6, 96, 194, 60
    CONTROL "O&rder:",                        -1, "STATIC", SS_LEFT | WS_CHILD | WS_VISIBLE | WS_GROUP, 10, 108, 40, 9
    CONTROL "MDY",                            IDC_DATEFMT_L_MDY, "BUTTON", BS_AUTORADIOBUTTON | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 54, 106, 30, 12
    CONTROL "DMY",                            IDC_DATEFMT_L_DMY, "BUTTON", BS_AUTORADIOBUTTON | WS_CHILD | WS_VISIBLE, 86, 106, 30, 12
    CONTROL "YMD",                            IDC_DATEFMT_L_YMD, "BUTTON", BS_AUTORADIOBUTTON | WS_CHILD | WS_VISIBLE, 118, 106, 30, 12
    CONTROL "",                               IDC_DATEFMT_L_COMBO1, "COMBOBOX", CBS_DROPDOWNLIST | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 8, 120, 44, 38
    CONTROL "",                               IDC_DATEFMT_L_EDIT1, "EDIT", ES_LEFT | ES_AUTOHSCROLL | ES_OEMCONVERT | WS_CHILD | WS_VISIBLE | WS_BORDER | WS_GROUP | WS_TABSTOP, 54, 120, 12, 12
    CONTROL "",                               IDC_DATEFMT_L_COMBO2, "COMBOBOX", CBS_DROPDOWNLIST | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 68, 120, 20, 30
    CONTROL "",                               IDC_DATEFMT_L_EDIT2, "EDIT", ES_LEFT | ES_AUTOHSCROLL | ES_OEMCONVERT | WS_CHILD | WS_VISIBLE | WS_BORDER | WS_GROUP | WS_TABSTOP, 90, 120, 12, 12
    CONTROL "",                               IDC_DATEFMT_L_COMBO3, "COMBOBOX", CBS_DROPDOWNLIST | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 104, 120, 48, 46
    CONTROL "",                               IDC_DATEFMT_L_EDIT3, "EDIT", ES_LEFT | ES_AUTOHSCROLL | ES_OEMCONVERT | WS_CHILD | WS_VISIBLE | WS_BORDER | WS_GROUP | WS_TABSTOP, 154, 120, 12, 12
    CONTROL "",                               IDC_DATEFMT_L_COMBO4, "COMBOBOX", CBS_DROPDOWNLIST | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 170, 120, 30, 30
    CONTROL "",                               IDC_DATEFMT_L_SAMPLE, "STATIC", SS_CENTER | SS_NOPREFIX | WS_CHILD | WS_VISIBLE | WS_GROUP, 8, 138, 168, 8
    CONTROL "OK",                             IDOK, "BUTTON", BS_DEFPUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 168, 2, 40, 14
    CONTROL "Cancel",                         IDCANCEL, "BUTTON", BS_PUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 168, 18, 40, 14
END

DLG_TIMEFMT DIALOG FIXED IMPURE  0, 98, 210, 70
STYLE DS_MODALFRAME | WS_POPUPWINDOW | WS_VISIBLE | WS_DLGFRAME
CAPTION "International - Time Format"
FONT 8, "Helv"
BEGIN
    CONTROL "1&2 hour",       IDC_TIMEFMT_12H, "BUTTON", BS_RADIOBUTTON | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 10, 4, 40, 12
    CONTROL "2&4 hour",       IDC_TIMEFMT_24H, "BUTTON", BS_RADIOBUTTON | WS_CHILD | WS_VISIBLE, 10, 18, 40, 12
    CONTROL "00:00-11:59",    257, "STATIC", SS_LEFT | SS_NOPREFIX | WS_CHILD | WS_VISIBLE, 50, 6, 40, 8
    CONTROL "",               IDC_TIMEFMT_AM, "EDIT", ES_LEFT | WS_CHILD | WS_VISIBLE | WS_BORDER | WS_GROUP | WS_TABSTOP, 98, 4, 40, 12
    CONTROL "12:00-23:59",    258, "STATIC", SS_LEFT | SS_NOPREFIX | WS_CHILD | WS_VISIBLE, 50, 20, 40, 8
    CONTROL "",               IDC_TIMEFMT_PM, "EDIT", ES_LEFT | WS_CHILD | WS_VISIBLE | WS_BORDER | WS_GROUP | WS_TABSTOP, 98, 18, 40, 12
    CONTROL "&Separator:",    -1, "STATIC", SS_LEFT | WS_CHILD | WS_VISIBLE | WS_GROUP, 10, 36, 40, 9
    CONTROL "",               IDC_TIMEFMT_SEP, "EDIT", ES_LEFT | WS_CHILD | WS_VISIBLE | WS_BORDER | WS_GROUP | WS_TABSTOP, 54, 34, 10, 12
    CONTROL "&Leading Zero:", -1, "STATIC", SS_LEFT | WS_CHILD | WS_VISIBLE | WS_GROUP, 10, 52, 52, 9
    CONTROL "9:15",           IDC_TIMEFMT_LZ_OFF, "BUTTON", BS_RADIOBUTTON | WS_CHILD | WS_VISIBLE | WS_GROUP, 64, 50, 30, 12
    CONTROL "09:15",          IDC_TIMEFMT_LZ_ON, "BUTTON", BS_RADIOBUTTON | WS_CHILD | WS_VISIBLE, 96, 50, 30, 12
    CONTROL "OK",             IDOK, "BUTTON", BS_DEFPUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 164, 4, 40, 14
    CONTROL "Cancel",         IDCANCEL, "BUTTON", BS_PUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 164, 20, 40, 14
END

#include "intl_currency.rc"
#include "intl_number.rc"

DLG_INTERNATIONAL DIALOG FIXED IMPURE 6, 0, 210, 172
STYLE DS_MODALFRAME | WS_POPUPWINDOW | WS_DLGFRAME
CAPTION "International"
FONT 8, "Helv"
BEGIN
    CONTROL "&Country:",            -1, "STATIC", SS_LEFT | WS_CHILD | WS_VISIBLE | WS_GROUP, 4, 4, 58, 9
    CONTROL "",                     IDC_INTL_COUNTRY, "COMBOBOX", CBS_DROPDOWNLIST | CBS_HASSTRINGS | WS_CHILD | WS_VISIBLE | WS_VSCROLL | WS_GROUP | WS_TABSTOP, 64, 2, 84, 78
    CONTROL "&Language:",           -1, "STATIC", SS_LEFT | WS_CHILD | WS_VISIBLE | WS_GROUP, 4, 24, 58, 9
    CONTROL "",                     IDC_INTL_LANGUAGE, "COMBOBOX", CBS_DROPDOWNLIST | CBS_HASSTRINGS | WS_CHILD | WS_VISIBLE | WS_VSCROLL | WS_GROUP | WS_TABSTOP, 64, 22, 84, 54
    CONTROL "&Keyboard Layout:",    -1, "STATIC", SS_LEFT | WS_CHILD | WS_VISIBLE | WS_GROUP, 4, 44, 58, 9
    CONTROL "",                     IDC_INTL_KEYBOARD, "COMBOBOX", CBS_DROPDOWNLIST | CBS_HASSTRINGS | WS_CHILD | WS_VISIBLE | WS_VSCROLL | WS_GROUP | WS_TABSTOP, 64, 42, 84, 54
    CONTROL "&Measurement:",        -1, "STATIC", SS_LEFT | WS_CHILD | WS_VISIBLE | WS_GROUP, 4, 64, 58, 9
    CONTROL "",                     IDC_INTL_MEASURE, "COMBOBOX", CBS_DROPDOWNLIST | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 64, 62, 84, 30
    CONTROL "List &Separator:",     -1, "STATIC", SS_LEFT | WS_CHILD | WS_VISIBLE | WS_GROUP, 4, 84, 58, 9
    CONTROL "",                     IDC_INTL_LISTSEP, "EDIT", ES_LEFT | WS_CHILD | WS_VISIBLE | WS_BORDER | WS_GROUP | WS_TABSTOP, 64, 82, 10, 12
    CONTROL "&D",                   IDC_INTL_ACCEL_DATE, "BUTTON", BS_PUSHBUTTON | WS_CHILD | WS_VISIBLE, 300, 200, 1, 1
    CONTROL "&Date Format",         IDC_INTL_DATE_GROUP, "BUTTON", BS_GROUPBOX | WS_CHILD | WS_VISIBLE, 2, 96, 112, 40
    CONTROL "3/5/90",               IDC_INTL_DATE_SHORT, "STATIC", SS_CENTER | SS_NOPREFIX | WS_CHILD | WS_VISIBLE | WS_GROUP, 4, 112, 50, 9
    CONTROL "Sunday, 5 March, 1990",IDC_INTL_DATE_LONG, "STATIC", SS_CENTER | SS_NOPREFIX | WS_CHILD | WS_VISIBLE | WS_GROUP, 4, 124, 108, 9
    CONTROL "Change...",            IDC_INTL_DATE_CHANGE, "BUTTON", BS_PUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 60, 108, 40, 14
    CONTROL "&U",                   IDC_INTL_ACCEL_CURR, "BUTTON", BS_PUSHBUTTON | WS_CHILD | WS_VISIBLE, 300, 200, 1, 1
    CONTROL "C&urrency Format",     IDC_INTL_CURR_GROUP, "BUTTON", BS_GROUPBOX | WS_CHILD | WS_VISIBLE, 116, 96, 92, 40
    CONTROL "$1.22",                IDC_INTL_CURR_POS, "STATIC", SS_CENTER | SS_NOPREFIX | WS_CHILD | WS_VISIBLE | WS_GROUP, 120, 112, 44, 9
    CONTROL "($1.22)",              IDC_INTL_CURR_NEG, "STATIC", SS_CENTER | SS_NOPREFIX | WS_CHILD | WS_VISIBLE | WS_GROUP, 120, 124, 44, 9
    CONTROL "Change...",            IDC_INTL_CURR_CHANGE, "BUTTON", BS_PUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 166, 116, 40, 14
    CONTROL "&T",                   IDC_INTL_ACCEL_TIME, "BUTTON", BS_PUSHBUTTON | WS_CHILD | WS_VISIBLE, 300, 200, 1, 1
    CONTROL "&Time Format",         IDC_INTL_TIME_GROUP, "BUTTON", BS_GROUPBOX | WS_CHILD | WS_VISIBLE, 2, 138, 112, 30
    CONTROL "9:30:01",              IDC_INTL_TIME_SAMPLE, "STATIC", SS_CENTER | SS_NOPREFIX | WS_CHILD | WS_VISIBLE | WS_GROUP, 4, 152, 50, 9
    CONTROL "Change...",            IDC_INTL_TIME_CHANGE, "BUTTON", BS_PUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 60, 150, 40, 14
    CONTROL "&N",                   IDC_INTL_ACCEL_NUM, "BUTTON", BS_PUSHBUTTON | WS_CHILD | WS_VISIBLE, 300, 200, 1, 1
    CONTROL "&Number Format",       IDC_INTL_NUM_GROUP, "BUTTON", BS_GROUPBOX | WS_CHILD | WS_VISIBLE, 116, 138, 92, 30
    CONTROL "1,234.4444",           IDC_INTL_NUM_SAMPLE, "STATIC", SS_CENTER | SS_NOPREFIX | WS_CHILD | WS_VISIBLE | WS_GROUP, 118, 152, 46, 9
    CONTROL "Change...",            IDC_INTL_NUM_CHANGE, "BUTTON", BS_PUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 166, 150, 40, 14
    CONTROL "OK",                   IDOK, "BUTTON", BS_DEFPUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 154, 2, 40, 14
    CONTROL "Cancel",               IDCANCEL, "BUTTON", BS_PUSHBUTTON | WS_CHILD | WS_VISIBLE | WS_GROUP | WS_TABSTOP, 154, 18, 40, 14
